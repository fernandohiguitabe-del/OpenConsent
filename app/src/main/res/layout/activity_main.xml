<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA">

    <!-- SWITCH SUPERIOR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#E8F0EF"
        android:padding="6dp">

        <Button
            android:id="@+id/btnSwitchUser"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="👤 Usuario"
            android:textSize="13sp"
            android:backgroundTint="#01696f"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="3dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnSwitchAdmin"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="🛡️ Administrador"
            android:textSize="13sp"
            android:backgroundTint="#C8D8D6"
            android:textColor="#7a7974"
            android:layout_marginStart="3dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

    <!-- CONTENEDOR DE FRAGMENTOS -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️ Panel de Administrador"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0c4e54"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OpenConsent+ — Accountability GDPR"
            android:textSize="11sp"
            android:textColor="#7a7974"
            android:layout_marginBottom="16dp"/>

        <!-- KPIs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#E8F5F5"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/txtTotalConsent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#01696f"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aceptados"
                    android:textSize="10sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FDF0E8"
                android:padding="10dp"
                android:layout_marginEnd="4dp">
                <TextView
                    android:id="@+id/txtTotalRevoked"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#964219"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Revocados"
                    android:textSize="10sp"
                    android:textColor="#555555"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FDF5FA"
                android:padding="10dp">
                <TextView
                    android:id="@+id/txtTotalRejected"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#a12c7b"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rechazados"
                    android:textSize="10sp"
                    android:textColor="#555555"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ESTADO POR USUARIO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥 Estado actual por usuario"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#28251d"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/containerUsuarios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"/>

        <!-- HISTORIAL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Historial de eventos"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#28251d"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:id="@+id/containerHistorial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"/>

        <!-- EXPORTAR -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬇️ Exportar para auditoría GDPR"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#28251d"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnExportLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exportar JSON"
            android:backgroundTint="#0c4e54"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exportar CSV"
            android:backgroundTint="#437a22"
            android:textColor="#FFFFFF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ Zona de mantenimiento"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#28251d"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnClearHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🗑️ Limpiar historial de pruebas"
            android:backgroundTint="#a12c7b"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>